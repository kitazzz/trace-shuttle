{
  "name": "@kitazzz/trace-shuttle-cli",
  "version": "0.1.1",
  "description": "CLI commands for reviewing and validating trace-shuttle annotations.",
  "license": "MIT",
  "author": "kitazzz",
  "keywords": [
    "traceability",
    "cli",
    "specification",
    "reporting"
  ],
  "type": "module",
  "bin": {
    "trace-shuttle": "dist/cli-entry.js"
  },
